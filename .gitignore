# Ignore ALL data and analysis outputs
data/
analysis/
logs/

# Keep folder structure with .gitkeep
!data/.gitkeep
!data/**/.gitkeep
!analysis/.gitkeep
!analysis/**/.gitkeep
!logs/.gitkeep

# Ignore bioinformatics files (extra safety)
*.fq.gz
*.fastq.gz
*.bam
*.sam
*.vcf
*.vcf.gz

# Ignore logs/temp
*.out
*.log
*.tmp
