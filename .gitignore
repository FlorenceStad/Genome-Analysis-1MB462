########################################
# CORE LARGE FILES (never track raw data)
########################################
*.fq.gz
*.fastq.gz
*.bam
*.sam
*.vcf*
*.bed
*.gff
*.gff3
*.gtf

########################################
# GENERAL SYSTEM FILES
########################################
*.log
*.out
*.tmp
slurm-*.out
logs/

########################################
# IGNORE ANALYSIS OUTPUTS
########################################
analysis/

########################################
# IGNORE RAW DATA FILE CONTENTS
########################################
data/raw_data/*

# Allow README
!data/raw_data/README.md

# Allow subdirectories (so Git can see inside them)
!data/raw_data/*/

# Allow symlinks (they appear as files, so allow specific patterns)
!data/raw_data/**/*.fq.gz
!data/raw_data/**/*.fastq.gz
!data/raw_data/**/*.hist
!data/raw_data/**/*.ktab



