# Global bioinf files
*.fq.gz
*.fastq.gz
*.bam
*.sam
*.vcf
*.vcf.gz

# LOGS / TEMP
logs/**
*.out
*.log
*.tmp

# Ignore raw data contents
data/raw_data/*

# Allow README
!data/raw_data/README.md

# Allow subdirectories to be traversed
!data/raw_data/*/

# Allow specific file types (including symlinks)
!data/raw_data/**/*.fq.gz
!data/raw_data/**/*.fastq.gz
!data/raw_data/**/*.hist
!data/raw_data/**/*.ktab
!data/raw_data/**/*.md

# Analysis outputs (selective ignore)
# Ignore heavy tool output folders
analysis/**/trimmed*/
analysis/**/flye*/
analysis/**/bwa*/
analysis/**/hisat2*/
analysis/**/tmp/
analysis/**/logs/

# Ignore BUSCO heavy internals but keep summaries
analysis/**/busco*/run_*/
analysis/**/busco*/logs/

# Ignore FastQC raw outputs but allow summaries
analysis/**/fastqc_*/**/*

# Allow Small and Useful files
# Allow reports & summaries everywhere
!analysis/**/*.txt
!analysis/**/*.tsv
!analysis/**/*.csv
!analysis/**/*.html
!analysis/**/*.pdf
!analysis/**/*.png

# Allow MultiQC outputs specifically
!analysis/**/multiqc_data/**
!analysis/**/multiqc_report.html


