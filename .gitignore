########################################
# CORE LARGE FILES (never track raw data)
########################################
*.fq.gz
*.fastq.gz
*.bam
*.sam
*.vcf*
*.bed
*.gff
*.gff3
*.gtf

########################################
# GENERAL SYSTEM FILES
########################################
*.log
*.out
*.tmp
slurm-*.out
logs/

########################################
# RAW DATA PROTECTION
########################################
data/raw_data/*

########################################
# IGNORE ALL ANALYSIS BY DEFAULT
########################################
analysis/*

########################################
# KEEP ONLY CURATED REPORTS
########################################

# FastQC / MultiQC
!analysis/**/fastqc/**/*.html
!analysis/**/multiqc*.html

# QUAST final reports only
!analysis/**/quast*/report.html
!analysis/**/quast*/report.pdf

# BUSCO summaries only
!analysis/**/busco*/**/short_summary*.txt
!analysis/**/busco*/**/short_summary*.json

########################################
# NEVER TRACK TOOL INTERNALS
########################################
analysis/**/busco*/run_*/
analysis/**/quast*/basic_stats/
analysis/**/flye*/
analysis/**/braker*/
analysis/**/repeatmasker*/
analysis/**/hisat2*/
analysis/**/stringtie*/
analysis/**/pilon*/
