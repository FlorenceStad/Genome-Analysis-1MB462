########################################
# CORE LARGE FILES (never track raw data)
########################################
*.fq.gz
*.fastq.gz
*.bam
*.sam
*.vcf*
*.bed
*.gff
*.gff3
*.gtf

########################################
# GENERAL SYSTEM FILES
########################################
*.log
*.out
*.tmp
slurm-*.out
logs/

########################################
# RAW DATA PROTECTION
########################################
data/raw_data/*

########################################
# IGNORE ALL ANALYSIS BY DEFAULT
########################################
analysis/*

########################################
# IGNORE ALL RAWDATA BY DEFAULT
########################################
data/raw_data/**
!data/raw_data/README.md

# Ignore bioinformatics files (extra safety)
# BUT allow symlinks and README
!data/raw_data/**/*.fq.gz
!data/raw_data/**/*.fastq.gz
!data/raw_data/**/*.hist
!data/raw_data/**/*.ktab
!data/raw_data/**/*.md





